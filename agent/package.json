{
  "name": "watson-rmm-agent",
  "version": "1.0.0",
  "description": "Watson RMM - Remote monitoring agent with screen streaming and command execution",
  "main": "service.js",
  "bin": "service.js",
  "scripts": {
    "start": "node service.js",
    "build": "pkg service.js --targets node18-win-x64 --output peng-rmm-agent.exe --compress Brotli"
  },
  "keywords": [
    "remote-monitoring",
    "rmm",
    "agent",
    "watson"
  ],
  "author": "Watson Parts",
  "license": "Proprietary",
  "pkg": {
    "assets": [
      "node_modules/node-windows/bin/winsw/winsw.exe"
    ]
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.0",
    "node-windows": "^1.0.0-beta.8",
    "screenshot-desktop": "^1.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
