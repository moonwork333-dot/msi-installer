<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  
  <?define ProductName = "Watson RMM Agent" ?>
  <?define ProductVersion = "1.0.0.0" ?>
  <?define ProductManufacturer = "Watson Parts" ?>
  <?define UpgradeCode = "12345678-1234-1234-1234-123456789012" ?>
  
  <Product Id="*" 
           Name="$(var.ProductName)" 
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="$(var.ProductManufacturer)" 
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="500" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="$(var.ProductName) Installer"
             Comments="Watson RMM Agent for remote monitoring and management" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <MediaTemplate EmbedCab="yes" />

    <!-- Directory Structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Watson RMM Agent" />
      </Directory>
    </Directory>

    <!-- Auto-generated files from heat.exe -->
    <Feature Id="ProductFeature" Title="Watson RMM Agent" Level="1">
      <ComponentGroupRef Id="ProductFiles" />
    </Feature>

    <!-- Custom Actions to install/remove service using batch files -->
    <!-- Setup script installs the service -->
    <CustomAction Id="SetupService" 
                  ExeCommand="cmd.exe /c setup.bat"
                  Directory="INSTALLFOLDER"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />
    
    <!-- Uninstall service when MSI is removed -->
    <CustomAction Id="UninstallService" 
                  ExeCommand="cmd.exe /c uninstall-service.bat"
                  Directory="INSTALLFOLDER"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="UninstallService" Before="RemoveFiles">(NOT UPGRADINGPRODUCTCODE) AND (REMOVE="ALL")</Custom>
      <Custom Action="SetupService" After="InstallFiles">NOT Installed</Custom>
    </InstallExecuteSequence>

    <!-- UI - Minimal installer -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\license.rtf" />

  </Product>
</Wix>
