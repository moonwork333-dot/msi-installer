<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  
  <?define ProductName = "Watson RMM Agent" ?>
  <?define ProductVersion = "1.0.0.0" ?>
  <?define ProductManufacturer = "Watson Parts" ?>
  <?define UpgradeCode = "12345678-1234-1234-1234-123456789012" ?>
  
  <Product Id="*" 
           Name="$(var.ProductName)" 
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="$(var.ProductManufacturer)" 
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="500" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="$(var.ProductName) Installer"
             Comments="Watson RMM Agent for remote monitoring and management" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <MediaTemplate EmbedCab="yes" />

    <!-- Directory Structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Watson RMM Agent" />
      </Directory>
    </Directory>

    <!-- Product Components -->
    <DirectoryRef Id="INSTALLFOLDER">
      <!-- Service files -->
      <Directory Id="ServiceDir" Name="service">
        <Component Id="ServiceJS" Guid="11111111-1111-1111-1111-111111111111">
          <File Id="ServiceJsFile" 
                Source="$(var.SourceDir)\service\service.js" 
                KeyPath="yes" />
        </Component>
        
        <Component Id="PackageJSON" Guid="22222222-2222-2222-2222-222222222222">
          <File Id="PackageJsonFile" 
                Source="$(var.SourceDir)\service\package.json" 
                KeyPath="yes" />
        </Component>

        <Component Id="RunServiceBat" Guid="33333333-3333-3333-3333-333333333333">
          <File Id="RunServiceBatFile" 
                Source="$(var.SourceDir)\service\run-service.bat" 
                KeyPath="yes" />
        </Component>

        <Component Id="ConfigFile" Guid="44444444-4444-4444-4444-444444444444">
          <File Id="ConfigJsonFile" 
                Source="$(var.SourceDir)\service\config.json" 
                KeyPath="yes" />
        </Component>

        <!-- Node modules -->
        <Component Id="NodeModules" Guid="55555555-5555-5555-5555-555555555555">
          <CreateFolder />
        </Component>
      </Directory>

      <!-- Batch scripts -->
      <Component Id="SetupBatchFile" Guid="66666666-6666-6666-6666-666666666666">
        <File Id="SetupBat" 
              Source="$(var.SourceDir)\setup.bat" 
              KeyPath="yes" />
      </Component>

      <!-- Install service batch file -->
      <Component Id="InstallBatchFile" Guid="77777777-7777-7777-7777-777777777777">
        <File Id="InstallBat" 
              Source="$(var.SourceDir)\install-service.bat" 
              KeyPath="yes" />
      </Component>

      <!-- Uninstall service batch file -->
      <Component Id="UninstallBatchFile" Guid="88888888-8888-8888-8888-888888888888">
        <File Id="UninstallBat" 
              Source="$(var.SourceDir)\uninstall-service.bat" 
              KeyPath="yes" />
      </Component>

      <!-- NSSM executable -->
      <Component Id="NSSMExecutable" Guid="99999999-9999-9999-9999-999999999999">
        <File Id="NssmExe" 
              Source="$(var.SourceDir)\nssm.exe" 
              KeyPath="yes" />
      </Component>

      <!-- Setup service VBS script -->
      <Component Id="SetupServiceVBS" Guid="AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA">
        <File Id="SetupServiceVbs" 
              Source="$(var.SourceDir)\setup-service.vbs" 
              KeyPath="yes" />
      </Component>

      <!-- License file -->
      <Component Id="LicenseFile" Guid="BBBBBBBB-BBBB-BBBB-BBBB-BBBBBBBBBBBB">
        <File Id="LicenseRtf" 
              Source="$(var.SourceDir)\license.rtf" 
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Custom Action - Run setup VBS -->
    <CustomAction Id="SetupService"
                  FileKey="SetupServiceVbs"
                  ExeCommand=""
                  Execute="immediate"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="SetupService" After="InstallFiles">NOT Installed</Custom>
    </InstallExecuteSequence>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Watson RMM Agent" Level="1">
      <ComponentRef Id="ServiceJS" />
      <ComponentRef Id="PackageJSON" />
      <ComponentRef Id="RunServiceBat" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="NodeModules" />
      <ComponentRef Id="SetupBatchFile" />
      <ComponentRef Id="InstallBatchFile" />
      <ComponentRef Id="UninstallBatchFile" />
      <ComponentRef Id="NSSMExecutable" />
      <ComponentRef Id="SetupServiceVBS" />
      <ComponentRef Id="LicenseFile" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\license.rtf" />

  </Product>
</Wix>
