<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  
  <?define ProductName = "Watson RMM Agent" ?>
  <?define ProductVersion = "1.0.0.0" ?>
  <?define ProductManufacturer = "Watson Parts" ?>
  <?define UpgradeCode = "12345678-1234-1234-1234-123456789012" ?>
  
  <Product Id="*" 
           Name="$(var.ProductName)" 
           Language="1033" 
           Version="$(var.ProductVersion)
           Manufacturer="$(var.ProductManufacturer)" 
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="500" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="$(var.ProductName) Installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Watson RMM Agent" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <!-- Support files at root level -->
      <Component Id="SetupBat" Guid="11111111-1111-1111-1111-111111111111">
        <File Id="SetupBatFile" Source="$(var.SourceDir)\setup.bat" KeyPath="yes" />
      </Component>

      <Component Id="InstallServiceBat" Guid="22222222-2222-2222-2222-222222222222">
        <File Id="InstallServiceBatFile" Source="$(var.SourceDir)\install-service.bat" KeyPath="yes" />
      </Component>

      <Component Id="UninstallServiceBat" Guid="33333333-3333-3333-3333-333333333333">
        <File Id="UninstallServiceBatFile" Source="$(var.SourceDir)\uninstall-service.bat" KeyPath="yes" />
      </Component>

      <Component Id="NssmExe" Guid="44444444-4444-4444-4444-444444444444">
        <File Id="NssmExeFile" Source="$(var.SourceDir)\nssm.exe" KeyPath="yes" />
      </Component>

      <Component Id="SetupServiceVbs" Guid="55555555-5555-5555-5555-555555555555">
        <File Id="SetupServiceVbsFile" Source="$(var.SourceDir)\setup-service.vbs" KeyPath="yes" />
      </Component>

      <Component Id="LicenseFile" Guid="66666666-6666-6666-6666-666666666666">
        <File Id="LicenseRtfFile" Source="$(var.SourceDir)\license.rtf" KeyPath="yes" />
      </Component>

      <!-- Service directory and core files -->
      <Directory Id="ServiceDirectory" Name="service">
        <Component Id="ServiceDirectory_Folder" Guid="77777777-7777-7777-7777-777777777777">
          <CreateFolder />
        </Component>

        <Component Id="ServiceJs" Guid="78787879-7878-7878-7878-787878787878">
          <File Id="ServiceJsFile" Source="$(var.SourceDir)\service\service.js" KeyPath="yes" />
        </Component>

        <Component Id="ServicePackageJson" Guid="88888888-8888-8888-8888-888888888888">
          <File Id="ServicePackageJsonFile" Source="$(var.SourceDir)\service\package.json" KeyPath="yes" />
        </Component>

        <Component Id="ServiceConfigJson" Guid="99999999-9999-9999-9999-999999999999">
          <File Id="ServiceConfigJsonFile" Source="$(var.SourceDir)\service\config.json" KeyPath="yes" />
        </Component>

        <Component Id="RunServiceBat" Guid="AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA">
          <File Id="RunServiceBatFile" Source="$(var.SourceDir)\service\run-service.bat" KeyPath="yes" />
        </Component>
      </Directory>
    </DirectoryRef>

    <!-- Custom Actions for copying service files -->
    <CustomAction Id="CopyServiceFilesAction" 
                  BinaryKey="ServiceCopyBinary"
                  DllEntry="CopyServiceFiles"
                  Execute="deferred"
                  Return="check"
                  Impersonate="no" />

    <CustomAction Id="SetupService"
                  FileKey="SetupServiceVbsFile"
                  ExeCommand=""
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Binary for custom action (inline PowerShell script) -->
    <Binary Id="ServiceCopyBinary" SourcePath="service_copy.dll" />

    <InstallExecuteSequence>
      <Custom Action="CopyServiceFilesAction" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="SetupService" After="CopyServiceFilesAction">NOT Installed</Custom>
    </InstallExecuteSequence>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Watson RMM Agent" Level="1">
      <ComponentRef Id="SetupBat" />
      <ComponentRef Id="InstallServiceBat" />
      <ComponentRef Id="UninstallServiceBat" />
      <ComponentRef Id="NssmExe" />
      <ComponentRef Id="SetupServiceVbs" />
      <ComponentRef Id="LicenseFile" />
      <ComponentRef Id="ServiceDirectory_Folder" />
      <ComponentRef Id="ServiceJs" />
      <ComponentRef Id="ServicePackageJson" />
      <ComponentRef Id="ServiceConfigJson" />
      <ComponentRef Id="RunServiceBat" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\license.rtf" />

  </Product>
</Wix>
