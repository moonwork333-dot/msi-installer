<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  
  <?define ProductName = "Watson RMM Agent" ?>
  <?define ProductVersion = "1.0.0.0" ?>
  <?define ProductManufacturer = "Watson Parts" ?>
  <?define UpgradeCode = "12345678-1234-1234-1234-123456789012" ?>
  
  <Product Id="*" 
           Name="$(var.ProductName)" 
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="$(var.ProductManufacturer)" 
           UpgradeCode="$(var.UpgradeCode)">
    
    <Package InstallerVersion="500" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="$(var.ProductName) Installer"
             Comments="Watson RMM Agent for remote monitoring and management" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    
    <MediaTemplate EmbedCab="yes" />

    <!-- Directory Structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Watson RMM Agent" />
      </Directory>
    </Directory>

    <!-- Product Components -->
    <DirectoryRef Id="INSTALLFOLDER">
      <!-- Main executable - This will be registered as a service -->
      <Component Id="MainExecutable" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="AgentExe" 
              Source="$(var.SourceDir)\peng-rmm-agent.exe" 
              KeyPath="yes" />
        
        <!-- WiX native service installation -->
        <ServiceInstall Id="WatsonRMMAgentService"
                        Name="WatsonRMMAgent"
                        DisplayName="Watson RMM Agent"
                        Description="Watson Remote Monitoring and Management Agent"
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Interactive="no"
                        Vital="yes" />
        
        <!-- Start service after installation -->
        <ServiceControl Id="StartWatsonRMMAgent"
                        Name="WatsonRMMAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
      
      <!-- Config file -->
      <Component Id="ConfigFile" Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012">
        <File Id="ConfigJson" 
              Source="$(var.SourceDir)\config.json" 
              KeyPath="yes" />
      </Component>

      <!-- Setup script -->
      <Component Id="SetupBatchFile" Guid="F7A8B9C0-D1E2-3456-CDEF-78901234ABCD">
        <File Id="SetupBat" 
              Source="$(var.SourceDir)\setup.bat" 
              KeyPath="yes" />
      </Component>

      <!-- Install service batch file -->
      <Component Id="InstallBatchFile" Guid="D4E5F6A7-B8C9-0123-CDEF-456789ABCDEF">
        <File Id="InstallBat" 
              Source="$(var.SourceDir)\install-service.bat" 
              KeyPath="yes" />
      </Component>

      <!-- Uninstall service batch file -->
      <Component Id="UninstallBatchFile" Guid="E5F6A7B8-C9D0-1234-CDEF-56789ABCDEF0">
        <File Id="UninstallBat" 
              Source="$(var.SourceDir)\uninstall-service.bat" 
              KeyPath="yes" />
      </Component>

      <!-- NSSM executable (for reference, not needed with WiX ServiceInstall) -->
      <Component Id="NSSMExecutable" Guid="C3D4E5F6-A7B8-9012-CDEF-34567890ABCD">
        <File Id="NssmExe" 
              Source="$(var.SourceDir)\nssm.exe" 
              KeyPath="yes" />
      </Component>

      <!-- License file -->
      <Component Id="LicenseFile" Guid="A7B8C9D0-E1F2-3456-CDEF-789ABCDE0123">
        <File Id="LicenseRtf" 
              Source="$(var.SourceDir)\license.rtf" 
              KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Features -->
    <Feature Id="ProductFeature" Title="Watson RMM Agent" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="SetupBatchFile" />
      <ComponentRef Id="InstallBatchFile" />
      <ComponentRef Id="UninstallBatchFile" />
      <ComponentRef Id="NSSMExecutable" />
      <ComponentRef Id="LicenseFile" />
    </Feature>

    <!-- UI -->
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\license.rtf" />

  </Product>
</Wix>
